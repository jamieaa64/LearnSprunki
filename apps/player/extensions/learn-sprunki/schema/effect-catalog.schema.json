{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LearnSprunki effect catalogue",
  "type": "object",
  "required": ["schemaVersion", "effects"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "effects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "type", "colors", "particlesPerNote", "lifetimeMs", "speed", "size"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "type": { "const": "note-sparks" },
          "colors": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "particlesPerNote": { "type": "integer", "minimum": 0, "maximum": 20 },
          "lifetimeMs": { "type": "number", "exclusiveMinimum": 0 },
          "speed": { "type": "number", "exclusiveMinimum": 0 },
          "size": { "type": "number", "exclusiveMinimum": 0 }
        }
      }
    }
  }
}
