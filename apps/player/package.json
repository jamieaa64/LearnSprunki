{
  "name": "neokeys-player",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Extensible tablet-friendly MIDI piano learner based on NeoKeys.",
  "scripts": {
    "dev": "python3 -m http.server 4173",
    "build": "node scripts/build.mjs",
    "validate:content": "node scripts/validate-content.mjs",
    "test": "node --test tests/unit/*.test.js tests/integration/*.test.js tests/architecture/*.test.js extensions/*/tests/*.test.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js",
    "test:architecture": "node --test tests/architecture/*.test.js",
    "check": "npm run validate:content && npm test && npm run build"
  },
  "dependencies": {
    "@tonejs/midi": "2.0.28",
    "midi-writer-js": "2.1.4",
    "tone": "14.8.49"
  }
}
