{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LearnSprunki game manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "title", "characters"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "id": { "type": "string" },
    "title": { "type": "string", "minLength": 1 },
    "characters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "color", "phases"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string", "minLength": 1 },
          "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
          "phases": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "title", "portrait", "locked", "lessonTrackId", "instrumentId", "effectId"],
              "properties": {
                "id": { "type": "string" },
                "title": { "type": "string" },
                "portrait": { "type": "string", "pattern": "^\\./content/" },
                "locked": { "type": "boolean" },
                "lessonTrackId": { "type": ["string", "null"] },
                "instrumentId": { "type": "string" },
                "effectId": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
