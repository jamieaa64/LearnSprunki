{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://learnsprunki.example/schemas/catalog.schema.json",
  "title": "LearnSprunki catalogue",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "title", "games", "resources", "tracks"],
  "properties": {
    "schemaVersion": { "const": "3.0.0" },
    "id": { "$ref": "#/$defs/id" },
    "title": { "$ref": "#/$defs/text" },
    "games": {
      "type": "array",
      "items": { "$ref": "#/$defs/gameReference" }
    },
    "resources": { "$ref": "#/$defs/resources" },
    "tracks": {
      "type": "array",
      "items": { "$ref": "#/$defs/track" }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "text": { "type": "string", "minLength": 1 },
    "asset": { "type": "string", "pattern": "^\\./content/" },
    "gameReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "manifest"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "title": { "$ref": "#/$defs/text" },
        "manifest": { "$ref": "#/$defs/asset" }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["instruments", "effects"],
      "properties": {
        "instruments": { "$ref": "#/$defs/asset" },
        "effects": { "$ref": "#/$defs/asset" }
      }
    },
    "theme": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "secondary", "leftHand", "rightHand", "background"],
      "properties": {
        "primary": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "secondary": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "leftHand": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "rightHand": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "background": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
      }
    },
    "animation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["idle", "frames", "frameDurationMs"],
      "properties": {
        "idle": { "$ref": "#/$defs/asset" },
        "frames": { "type": "array", "items": { "$ref": "#/$defs/asset" } },
        "frameDurationMs": { "type": "integer", "minimum": 16 }
      }
    },
    "lesson": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gameId", "characterId", "phaseId", "playerMode", "loopByDefault", "loopDurationMs", "instrumentId", "effectId", "referenceAudio", "theme", "animation"],
      "properties": {
        "gameId": { "$ref": "#/$defs/id" },
        "characterId": { "$ref": "#/$defs/id" },
        "phaseId": { "$ref": "#/$defs/id" },
        "playerMode": { "enum": ["piano", "rhythm"] },
        "loopByDefault": { "type": "boolean" },
        "loopDurationMs": { "type": "number", "exclusiveMinimum": 0 },
        "instrumentId": { "$ref": "#/$defs/id" },
        "effectId": { "$ref": "#/$defs/id" },
        "rhythmLabel": { "$ref": "#/$defs/text" },
        "rhythmMidiNote": { "type": "integer", "minimum": 0, "maximum": 127 },
        "referenceAudio": { "$ref": "#/$defs/asset" },
        "theme": { "$ref": "#/$defs/theme" },
        "animation": { "$ref": "#/$defs/animation" }
      }
    },
    "transcription": {
      "type": "object",
      "additionalProperties": true,
      "required": ["engine", "engineVersion", "sourceAudio", "reviewRequired", "parameters"],
      "properties": {
        "engine": { "$ref": "#/$defs/id" },
        "engineVersion": { "$ref": "#/$defs/text" },
        "sourceAudio": { "$ref": "#/$defs/text" },
        "reviewRequired": { "type": "boolean" },
        "parameters": { "type": "object" }
      }
    },
    "track": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "filename", "midi", "kind"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "title": { "$ref": "#/$defs/text" },
        "subtitle": { "type": "string" },
        "filename": { "type": "string", "pattern": "\\.mid(?:i)?$" },
        "emoji": { "type": "string" },
        "midi": { "type": "string", "pattern": "^\\./content/.*\\.mid(?:i)?$" },
        "kind": { "enum": ["demo", "sprunki-lesson"] },
        "reviewStatus": { "enum": ["draft", "reviewed", "approved"] },
        "lesson": { "$ref": "#/$defs/lesson" },
        "transcription": { "$ref": "#/$defs/transcription" }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "sprunki-lesson" } } },
          "then": { "required": ["lesson", "reviewStatus"] }
        }
      ]
    }
  }
}
